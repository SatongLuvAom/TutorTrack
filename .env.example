DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutortrack?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-at-least-32-characters"
PAYMENT_PROVIDER="OMISE"

# Omise/Opn PromptPay. Keep the secret key server-only.
OMISE_PUBLIC_KEY="pkey_test_replace_me"
NEXT_PUBLIC_OMISE_PUBLIC_KEY="pkey_test_replace_me"
OMISE_SECRET_KEY="skey_test_replace_me"
# Use as a shared token in the webhook URL or header when your provider setup allows it.
OMISE_WEBHOOK_SECRET="replace-with-random-webhook-secret"

# Optional: set to true only for disposable demo deployments that intentionally
# allow seeded @tutortrack.test accounts to use the shared demo password.
# ALLOW_DEMO_PASSWORD_LOGIN="false"

# Optional: set this when your database user cannot create Prisma shadow databases.
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutortrack_shadow?schema=public"
